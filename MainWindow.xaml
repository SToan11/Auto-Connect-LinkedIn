<Window x:Class="AutoConnectLinkedIn.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Auto Connect LinkedIn" 
        Height="730" Width="631"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <Grid>
        <Border Background="White"
                CornerRadius="12"
                Padding="30"
                Width="300"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <StackPanel>
                <TextBlock Text="AUTO CONNECT"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#333"
                           HorizontalAlignment="Center"
                           Margin="0 0 0 20"/>

                <TextBlock Text="Email" FontSize="14" Foreground="#555"/>
                <TextBox x:Name="EmailBox"
                         Height="32"
                         Margin="0 5 0 15"
                         Padding="5"
                         Background="#FAFAFA"/>

                <TextBlock Text="Password" FontSize="14" Foreground="#555"/>

                <Grid Margin="0 5 0 20">
                    <!-- PasswordBox (ẩn) -->
                    <PasswordBox x:Name="PasswordBox"
                                 Height="32"
                                 Padding="5"
                                 Background="#FAFAFA"
                                 VerticalContentAlignment="Center"/>        

                    <!-- TextBox (hiện) -->
                    <TextBox x:Name="PasswordTextBox"
                             Height="32"
                             Padding="5"
                             Background="#FAFAFA"
                             VerticalContentAlignment="Center"
                             Visibility="Collapsed"/>           

                    <!-- Button 👁 -->
                    <Button x:Name="TogglePasswordBtn"
                            Width="35"
                            Height="32"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="TogglePassword_Click">
                        <TextBlock Text="👁" FontSize="16"/>
                    </Button>
                </Grid>


                <Button Content="Start"
                        Height="38"
                        x:Name="StartButton"
                        Background="#3B82F6"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0 10 0 0"
                        Click="Button_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
